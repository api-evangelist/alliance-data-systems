{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://raw.githubusercontent.com/api-evangelist/alliance-data-systems/main/json-schema/bread-classic-cart-item-schema.json",
  "title": "BreadClassicCartItem",
  "description": "Line item within a Bread Classic cart.",
  "type": "object",
  "required": ["name", "unitPrice", "quantity"],
  "properties": {
    "name": { "type": "string" },
    "sku": { "type": "string" },
    "unitPrice": {
      "type": "integer",
      "description": "Unit price in minor units (cents)."
    },
    "quantity": { "type": "integer", "minimum": 1 },
    "imageUrl": { "type": "string", "format": "uri" }
  }
}
